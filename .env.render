# Configuration pour Render (sans TiDB)
NODE_ENV=production
PORT=3001

# JWT Configuration
JWT_SECRET=votre_jwt_secret_key_2024_secure_unique_pour_render
JWT_EXPIRES_IN=7d

# CORS Configuration
FRONTEND_URL=https://kung-fu-frontend.vercel.app

# Base de données (optionnel - MySQL local si disponible)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=sportgym_local
