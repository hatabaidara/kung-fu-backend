# Configuration pour Render (avec TiDB)
NODE_ENV=production
PORT=3001

# JWT Configuration
JWT_SECRET=votre_jwt_secret_key_2024_secure_unique_pour_render
JWT_EXPIRES_IN=7d

# CORS Configuration
FRONTEND_URL=https://kung-fu-frontend.vercel.app

# TiDB Cloud Configuration
TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_username_here
TIDB_PASSWORD=your_password_here
TIDB_DATABASE=sportgym_db

# SSL Configuration (for TiDB Cloud)
SSL_MODE=REQUIRED
