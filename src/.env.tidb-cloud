# TiDB Cloud Configuration
TIDB_CLOUD_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_CLOUD_PORT=4000
TIDB_CLOUD_USER=your_username_here
TIDB_CLOUD_PASSWORD=your_password_here
TIDB_CLOUD_DATABASE=sportgym_db

# JWT Configuration
JWT_SECRET=sportgym_jwt_secret_key_2024_secure_tidb_cloud
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001
NODE_ENV=production

# CORS Configuration
FRONTEND_URL=https://your-frontend-domain.com

# SSL Configuration (for TiDB Cloud)
SSL_MODE=REQUIRED
