{
  "name": "sportgym-backend",
  "version": "1.0.0",
  "description": "Backend for Sport Gym Management App",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "docker build -t sportgym-backend .",
    "docker:run": "docker run -p 3001:3001 sportgym-backend",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "tidb:init": "node init-db.js",
    "tidb:test": "node -e \"require('./config/database').testConnection()\"",
    "k8s:deploy": "kubectl apply -f deploy/k8s-tidb.yaml",
    "k8s:delete": "kubectl delete -f deploy/k8s-tidb.yaml"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "mysql2": "^3.6.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": ["gym", "management", "tidb", "express"],
  "author": "",
  "license": "MIT"
}
